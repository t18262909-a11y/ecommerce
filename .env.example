# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model to use (gpt-4o-mini is fast + cheap for this task)
OPENAI_MODEL=gpt-4o-mini

# Backend port
PORT=3000

# CORS — your Shopify store URL(s), comma-separated. Use * for dev only.
ALLOWED_ORIGIN=*

# Minimum session duration (seconds) before LLM is even called.
# Saves tokens by filtering out throwaway sessions at the API layer.
MIN_SESSION_SECONDS=25

# How often (ms) the backend will respond with show=true to the SAME session.
# Prevents spamming one user with multiple popups.
SESSION_COOLDOWN_MS=120000
